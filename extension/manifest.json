{
  "manifest_version": 3,
  "name": "Flow Image Automator",
  "description": "Queue and auto-generate images on Google Flow with sequential prompts and auto-download.",
  "version": "1.4.1",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Flow Image Automator",
    "default_popup": "sidepanel/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://labs.google/*",
    "https://*.googleusercontent.com/*",
    "https://*.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/*"
      ],
      "js": [
        "content/lib/dom.js",
        "content/lib/targeting.js",
        "content/lib/agent.js",
        "content/lib/images.js",
        "content/lib/composer.js",
        "content/flow.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
